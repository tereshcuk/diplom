###
get http://127.0.0.1:8000/api/v1/files/
Content-Type: application/json
# Authorization: Token 70cc3c7f718950ca3138c74d7ec04d2b0bfcce41

###
post http://127.0.0.1:8000/api/v1/login/
Content-Type: application/json

{
    "username": "test6",
    "password": "A2345!"
}

###
post http://127.0.0.1:8000/api/v1/logout/
# X-CSRFToken: {csrf_token}
# Authorization: Token ad7e398ef72fe7e6f0d6de41fbe595a8ad07da64
# credentials: "include" 

###
post http://127.0.0.1:8000/api/v1/register/
Content-Type: application/json

{
    "username": "test8",
    "email": "test8@yandex.ru",
    "password": "A2345!",
    "full_name": "Тест8",
    "is_admin": false
}


# Файлы
# получение списка файлов пользователя. Для админов — с параметром ?user_id=
###
get http://127.0.0.1:8000/api/v1/files/
Content-Type: application/json
# Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068

###
curl -X GET "http://127.0.0.1:8000/api/v1/files" \
-H "Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068"

###
get http://127.0.0.1:8000/api/v1/files/?user=16
Content-Type: application/json
# Authorization: Token 70cc3c7f718950ca3138c74d7ec04d2b0bfcce41

###
get http://127.0.0.1:8000/api/v1/files/16/
Content-Type: application/json
# Authorization: Token 70cc3c7f718950ca3138c74d7ec04d2b0bfcce41

###
get http://127.0.0.1:8000/api/v1/files/get_file_path/
Content-Type: application/json
# Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068


#Загрузить файл
###
curl -X POST http://127.0.0.1:8000/api/v1/files/ \
-H "Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068" \
-F "file=@D:/test.txt" \
-F "original_name=test.txt"

# Удаление файла 
###
DELETE http://127.0.0.1:8000/api/v1/files/1/
Content-Type: application/json
Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068

###
curl -X DELETE http://127.0.0.1:8000/api/v1/files/2/ \
     -H "Authorization: Token 4d53c2a6481f51483ba751d694734cc227269068"


# Переименовать файл
###
put http://127.0.0.1:8000/api/v1/files/2/rename/
Content-Type: application/json
# Authorization: Token 70cc3c7f718950ca3138c74d7ec04d2b0bfcce41 

{
    "original_name": "Мой отчет.pdf"
}


###
curl -X PUT http://127.0.0.1:8000/api/v1/files/2/rename/ \
     -H "Authorization: Token 70cc3c7f718950ca3138c74d7ec04d2b0bfcce41" \
     -H "Content-Type: application/json" \
     -d '{"original_name": "Новое имя файла.txt"}'


# Добавление комментария
###
put http://127.0.0.1:8000/api/v1/files/6/comment/
Content-Type: application/json
Authorization: Token 61fb4a3a5a4655a9eb343219475b34805f365716 

{
    "comment": "Мой отчет.pdf - Это супер"
}



